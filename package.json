{
  "name": "finder-mcp-server",
  "version": "1.0.2",
  "description": "Per-app MCP server for macOS Finder — hardcoded AppleScript only, no shell script access",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "finder-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "macos",
    "finder",
    "applescript",
    "automation"
  ],
  "license": "MIT"
}
